   "source": [
    "# LLM Dashboard – OpenRouter\n",
    "Chạy từng cell theo thứ tự. Cell cuối sẽ mở giao diện web."
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# Cell 1 – Cài thư viện\n",
    "!pip install -q gradio requests"
   ],
   "outputs": [],
   "execution_count": null
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# Cell 2 – Nhập OpenRouter API key\n",
    "from google.colab import userdata\n",
    "import os\n",
    "\n",
    "# Cách 1: Lấy từ Colab Secrets (khuyến nghị)\n",
    "# Vào menu bên trái > biểu tượng khoá > thêm secret tên OPENROUTER_API_KEY\n",
    "try:\n",
    "    API_KEY = userdata.get('OPENROUTER_API_KEY')\n",
    "    print('Đã lấy API key từ Colab Secrets.')\n",
    "except Exception:\n",
    "    # Cách 2: Nhập thủ công\n",
    "    import getpass\n",
    "    API_KEY = getpass.getpass('Nhập OpenRouter API key: ')"
   ],
   "outputs": [],
   "execution_count": null
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# Cell 3 – Hàm gọi API\n",
    "import requests\n",
    "\n",
    "ALLOWED_MODELS = [\n",
    "    \"openrouter/auto\",\n",
    "    \"owl-alpha\",\n",
    "    \"nvidia/nemotron-3-8b-instruct\",\n",
    "    \"poolside/laguna-m1\",\n",
    "]\n",
    "\n",
    "def chat(model: str, prompt: str) -> str:\n",
    "    if not prompt.strip():\n",
    "        return 'Prompt không được để trống.'\n",
    "    if model not in ALLOWED_MODELS:\n",
    "        return 'Model không hợp lệ.'\n",
    "\n",
    "    try:\n",
    "        resp = requests.post(\n",
    "            'https://openrouter.ai/api/v1/chat/completions',\n",
    "            headers={\n",
    "                'Authorization': f'Bearer {API_KEY}',\n",
    "                'Content-Type': 'application/json',\n",
    "            },\n",
    "            json={\n",
    "                'model': model,\n",
    "                'messages': [{'role': 'user', 'content': prompt}],\n",
    "                'max_tokens': 1024,\n",
    "                'temperature': 0.7,\n",
    "            },\n",
    "            timeout=60,\n",
    "        )\n",
    "        resp.raise_for_status()\n",
    "        data = resp.json()\n",
    "        return data['choices'][0]['message']['content']\n",
    "    except requests.exceptions.Timeout:\n",
    "        return 'Lỗi: API timeout sau 60 giây.'\n",
    "    except requests.exceptions.HTTPError as e:\n",
    "        return f'Lỗi HTTP {e.response.status_code}: {e.response.text[:300]}'\n",
    "    except Exception as e:\n",
    "        return f'Lỗi: {e}'"
   ],
   "outputs": [],
   "execution_count": null
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# Cell 4 – Giao diện Gradio\n",
    "import gradio as gr\n",
    "\n",
    "with gr.Blocks(title='LLM Dashboard') as demo:\n",
    "    gr.Markdown('# LLM Dashboard – OpenRouter')\n",
    "\n",
    "    with gr.Row():\n",
    "        model_dd = gr.Dropdown(\n",
    "            choices=ALLOWED_MODELS,\n",
    "            value=ALLOWED_MODELS[0],\n",
    "            label='Model',\n",
    "        )\n",
    "\n",
    "    prompt_box = gr.Textbox(\n",
    "        lines=5,\n",
    "        placeholder='Nhập prompt tại đây...',\n",
    "        label='Prompt',\n",
    "    )\n",
    "    send_btn = gr.Button('Gửi', variant='primary')\n",
    "    output_box = gr.Textbox(label='Phản hồi', lines=10, interactive=False)\n",
    "\n",
    "    send_btn.click(fn=chat, inputs=[model_dd, prompt_box], outputs=output_box)\n",
    "    prompt_box.submit(fn=chat, inputs=[model_dd, prompt_box], outputs=output_box)\n",
    "\n",
    "demo.launch(share=True)  # share=True tạo link public dùng được ngoài Colab"
   ],
   "outputs": [],
   "execution_count": null
  }
 ]
}"
