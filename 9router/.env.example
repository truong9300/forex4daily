# Copy to .env and fill in your API keys

# Which provider to use by default (claude/openai/deepseek/openrouter/gemini/nvidia/groq/mistral/together)
ACTIVE_PROVIDER=claude

# Provider API keys (leave blank for providers you don't use)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...
OPENROUTER_API_KEY=sk-or-...
GEMINI_API_KEY=AIza...
NVIDIA_API_KEY=nvapi-...
GROQ_API_KEY=gsk_...
MISTRAL_API_KEY=...
TOGETHER_API_KEY=...
